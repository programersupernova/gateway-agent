PORT=8080

# Shared secret between backend and agent (MVP)
AGENT_TOKEN=supersecret-agent-token

# WireGuard
WG_INTERFACE=wg0

# Auto register (optional but recommended)
BACKEND_URL=https://api.yourvpn.com
BOOTSTRAP_TOKEN=bootstrap-token-from-backend
REGION=SG
VPN_CIDR=10.10.0.0/16
WG_PORT=51820

# Agent "advertise" URL (how backend reaches this agent)
# If backend talks over private network, set private IP:
AGENT_BASE_URL=http://10.0.0.10:8080
